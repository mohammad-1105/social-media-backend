{
  "name": "social-media-backend",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "Mohammad Aman",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc && tsc-alias",
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run build",
    "dev": "pnpm run \"/dev:/\"",
    "dev:alias": "tsc-alias --watch",
    "dev:node": "node --enable-source-maps --watch dist/index.js",
    "dev:tsc": "tsc --watch --preserveWatchOutput",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "hooks:install": "husky",
    "hooks:pre-commit": "sh .husky/pre-commit",
    "lint": "oxlint . --tsconfig tsconfig.json",
    "lint:fix": "oxlint . --fix --tsconfig tsconfig.json",
    "prepare": "husky",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.3.2",
    "morgan": "1.10.1",
    "validator": "13.15.26",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/validator": "^13.15.10",
    "husky": "^9.1.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
