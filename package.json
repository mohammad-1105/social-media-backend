{
  "name": "modular-auth-api",
  "version": "1.0.0",
  "description": "A modular authentication API built with Node.js, Express, TypeScript, and MongoDB, featuring JWT auth, email verification, password recovery, and role-based access control.",
  "keywords": [
    "auth",
    "auth-api",
    "clean-architecture",
    "email-verification",
    "express",
    "jwt",
    "modular-architecture",
    "mongodb",
    "nodejs",
    "password-reset",
    "rest-api",
    "typescript"
  ],
  "license": "ISC",
  "author": "Mohammad Aman",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run build",
    "dev": "concurrently \"pnpm dev:tsc\" \"pnpm dev:alias\" \"pnpm dev:node\"",
    "dev:alias": "tsc-alias --watch",
    "dev:node": "cross-env NODE_ENV=development node --enable-source-maps --watch dist/index.js",
    "dev:tsc": "tsc --watch --preserveWatchOutput",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "hooks:pre-commit": "sh .husky/pre-commit",
    "lint": "oxlint . --tsconfig tsconfig.json",
    "lint:fix": "oxlint . --fix --tsconfig tsconfig.json",
    "prepare": "husky",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mailgen": "^2.0.32",
    "mongoose": "9.3.2",
    "morgan": "1.10.1",
    "nodemailer": "^8.0.4",
    "validator": "13.15.26",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/request-ip": "^0.0.41",
    "@types/validator": "^13.15.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
