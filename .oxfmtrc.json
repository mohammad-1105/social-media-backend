{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["dist/**", "node_modules/**", "coverage/**"],
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "objectWrap": "preserve",
  "proseWrap": "preserve",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortImports": {
    "internalPattern": ["@/"],
    "newlinesBetween": true,
    "sortSideEffects": false
  },
  "sortPackageJson": {
    "sortScripts": true
  }
}
