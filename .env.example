# ------------------------------------------------------------
# App Runtime
# ------------------------------------------------------------

# App environment: development | test | production
NODE_ENV="development"

# Port your API server listens on
PORT="3000"


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# MongoDB connection string
# Example:
# mongodb://127.0.0.1:27017/modular-auth-api
DATABASE_URL=""


# ------------------------------------------------------------
# Frontend / Public URLs
# ------------------------------------------------------------

# Allowed frontend origins for CORS
# Use "*" only for simple local development
# In production, prefer one or more explicit origins separated by commas
# Example:
# https://app.example.com,https://admin.example.com
CORS_ORIGIN="*"

# Public backend base URL used in email verification links
# In production, this should be your real public API domain
# Example:
# https://api.example.com
API_PUBLIC_URL="http://localhost:3000"

# Frontend reset-password page base URL
# If this is set, password reset emails will point users to this page
# Example:
# https://app.example.com/reset-password
FORGOT_PASSWORD_REDIRECT_URL="http://localhost:5173/reset-password"


# ------------------------------------------------------------
# JWT Tokens
# ------------------------------------------------------------

# Long random secret used to sign access tokens
ACCESS_TOKEN_SECRET=""

# Short-lived access token expiry
# Examples: 15m, 1h
ACCESS_TOKEN_EXPIRY="15m"

# Long random secret used to sign refresh tokens
REFRESH_TOKEN_SECRET=""

# Longer-lived refresh token expiry
# Examples: 7d, 30d
REFRESH_TOKEN_EXPIRY="7d"


# ------------------------------------------------------------
# SMTP / Email Delivery
# ------------------------------------------------------------

# SMTP host from your email provider
SMTP_HOST=""

# SMTP port
# Common values: 587 (TLS), 465 (SSL)
SMTP_PORT="587"

# SMTP username or sender email address
SMTP_USER=""

# SMTP password or app password
SMTP_PASS=""
